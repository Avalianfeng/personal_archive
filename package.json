{
  "name": "personal-archive",
  "private": true,
  "scripts": {
    "dev:personality": "concurrently \"pnpm dev:personality:api\" \"pnpm dev:personality:web\"",
    "dev:personality:web": "pnpm --filter @personal-archive/personality-web dev",
    "dev:personality:api": "pnpm --filter @personal-archive/personality-api dev",
    "dev:archive": "pnpm --filter @personal-archive/archive-web dev",
    "dev": "pnpm dev:personality",
    "build:personality": "pnpm --filter @personal-archive/personality-web build && pnpm --filter @personal-archive/personality-api build",
    "build:archive": "pnpm --filter @personal-archive/archive-web build",
    "build": "pnpm build:personality"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@tsparticles/engine"
    ]
  }
}
