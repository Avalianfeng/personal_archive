{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-archive.local/questions/question.schema.json",
  "title": "Question",
  "description": "Compiled question object from categories/*.md (v0.4)",
  "type": "object",
  "required": [
    "uid",
    "id",
    "category",
    "category_label",
    "subcategory",
    "type",
    "status",
    "text",
    "source_file"
  ],
  "properties": {
    "uid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}$"
    },
    "id": {
      "type": "string",
      "pattern": "^Q-(REAL|EMO|DEC|STA|SELF|VAL|OTH)-[0-9]{3}$"
    },
    "category": {
      "type": "string",
      "enum": ["real", "emo", "dec", "sta", "self", "val", "oth"]
    },
    "category_label": { "type": "string" },
    "subcategory": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["open", "single", "multi", "scale", "sort", "fill", "agreement"]
    },
    "prerequisites": {
      "type": ["array", "null"],
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "interaction": {
      "type": ["string", "null"],
      "enum": [
        "story",
        "self_report",
        "scenario",
        "comparison",
        "rating",
        "reflection",
        "future",
        null
      ]
    },
    "source": { "type": ["string", "null"] },
    "tags": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "depth": {
      "type": ["string", "null"],
      "enum": ["shallow", "medium", "deep", null]
    },
    "validation": { "type": "boolean" },
    "related": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["active", "candidate", "deprecated"]
    },
    "order": { "type": ["integer", "null"] },
    "superseded_by": { "type": ["string", "null"] },
    "deprecated_reason": { "type": ["string", "null"] },
    "text": { "type": "string", "minLength": 1 },
    "options": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["key", "text"],
        "properties": {
          "key": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "scale": { "type": ["string", "null"] },
    "source_file": { "type": "string" }
  },
  "additionalProperties": false
}
